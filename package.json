{
  "name": "nano-harness",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev": "pnpm --filter @nano-harness/desktop dev",
    "build": "pnpm -r run build",
    "pack:mac": "pnpm --filter @nano-harness/desktop pack:mac",
    "dist:mac": "pnpm --filter @nano-harness/desktop dist:mac",
    "pack:win": "pnpm --filter @nano-harness/desktop pack:win",
    "dist:win": "pnpm --filter @nano-harness/desktop dist:win",
    "pack:linux": "pnpm --filter @nano-harness/desktop pack:linux",
    "dist:linux": "pnpm --filter @nano-harness/desktop dist:linux",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc -p tsconfig.tests.json --noEmit && pnpm -r run typecheck",
    "lint": "pnpm -r run lint"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "25.6.0",
    "@vitest/coverage-v8": "4.1.5",
    "jsdom": "29.1.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.1",
    "vitest": "4.1.5"
  }
}
