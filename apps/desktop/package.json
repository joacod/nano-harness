{
  "name": "@nano-harness/desktop",
  "productName": "Nano Harness",
  "private": true,
  "version": "0.0.1",
  "description": "Local-first desktop harness for experimenting with agent runs and tool execution.",
  "author": "Joaquin Diaz <dev@joacod.com>",
  "type": "module",
  "packageManager": "pnpm@10.33.2",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "prepare:mac-icon": "sh scripts/generate-mac-icon.sh",
    "pack:mac": "pnpm prepare:mac-icon && pnpm build && electron-builder --mac --dir --config electron-builder.yml",
    "dist:mac": "pnpm prepare:mac-icon && pnpm build && electron-builder --mac --config electron-builder.yml",
    "pack:win": "pnpm build && electron-builder --win --dir --config electron-builder.yml",
    "dist:win": "pnpm build && electron-builder --win --config electron-builder.yml",
    "pack:linux": "pnpm build && electron-builder --linux --dir --config electron-builder.yml",
    "dist:linux": "pnpm build && electron-builder --linux --config electron-builder.yml",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@libsql/client": "0.17.3",
    "@nano-harness/core": "workspace:*",
    "@nano-harness/infra": "workspace:*",
    "@nano-harness/shared": "workspace:*",
    "@tanstack/react-form": "1.29.1",
    "@tanstack/react-query": "5.100.1",
    "@tanstack/react-router": "1.168.23",
    "drizzle-orm": "0.45.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "streamdown": "2.5.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "41.3.0",
    "electron-builder": "26.8.1",
    "electron-vite": "5.0.0",
    "eslint": "10.2.1",
    "vite": "7.3.2"
  }
}
